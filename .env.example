# Copy this to .env and fill in your real values. NEVER commit .env.
# Aliyun Bailian (阿里云百炼) — recommended default
PD_API_KEY=sk-your-key-here
PD_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PD_MODEL=qwen-plus

# Optional
PD_PROVIDER_NAME=aliyun-bailian
PD_PDF_TIMEOUT=60
PD_MIN_SURVEY=2

# Optional: Semantic Scholar API key (free, raises rate limit). Apply at
# https://www.semanticscholar.org/product/api. Without it, the free tier
# (100 req / 5 min) is sufficient for personal use.
PD_SS_API_KEY=
