# Copy this to .env (in your project root) and fill in your real values.
# NEVER commit your .env.

# Aliyun Bailian (recommended default)
PD_API_KEY=sk-your-key-here
PD_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PD_MODEL=qwen-plus

# Optional
PD_PROVIDER_NAME=aliyun-bailian
PD_PDF_TIMEOUT=60
PD_MIN_SURVEY=2
